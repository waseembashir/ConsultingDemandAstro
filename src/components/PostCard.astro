---
interface Props {
  title: string;
  excerpt: string;
  category: string;
  slug: string;
  publishDate: Date;
  updatedDate?: Date;
  readTime: string;
  author: string;
  authorInitials: string;
  featured?: boolean;
  size?: 'normal' | 'wide'; // wide = card 7 horizontal style
  coverImage?: string;
}

const {
  title,
  excerpt,
  category,
  slug,
  publishDate,
  updatedDate,
  readTime,
  author,
  authorInitials,
  featured = false,
  size = 'normal',
  coverImage,
} = Astro.props;

const displayDate = updatedDate || publishDate;
const formattedDate = displayDate.toLocaleDateString('en-GB', {
  month: 'long',
  year: 'numeric',
});
---

<article class="post-card-wrapper" data-category={category}>
  <a href={`/blog/${slug}`} class:list={['post-card', { featured, wide: size === 'wide' }]}>
    <div class="card-image">
      {coverImage ? (
        <img
          src={coverImage}
          alt=""
          class="card-image-img"
          loading="lazy"
          decoding="async"
          width="1200"
          height="630"
        />
      ) : (
        <div class="card-image-inner" aria-hidden="true"></div>
      )}
      <span class="card-category">{category}</span>
    </div>
    <div class="card-body">
      <div class="card-meta">
        <time datetime={displayDate.toISOString().slice(0, 10)}>{formattedDate}</time>
        <span class="card-meta-dot" aria-hidden="true"></span>
        <span>{readTime}</span>
      </div>
      <h2 class="card-title">{title}</h2>
      <p class="card-excerpt">{excerpt}</p>
    </div>
    <div class="card-footer">
      <div class="card-avatar" aria-hidden="true">{authorInitials}</div>
      <span class="card-author-name">{author}</span>
    </div>
  </a>
</article>

<style>
.post-card-wrapper { height: 100%; }
.post-card {
  display: block;
  height: 100%;
  background: var(--white);
  border-radius: 20px;
  overflow: hidden;
  transition: all 0.5s var(--ease-out);
  border: 1px solid rgba(0,0,0,0.06);
  position: relative;
  text-decoration: none;
  color: inherit;
}
.post-card::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4px;
  z-index: 2;
  opacity: 0;
  background: linear-gradient(90deg, var(--orange), var(--magenta));
  transition: opacity 0.4s;
  border-radius: 0 0 20px 20px;
}
.post-card:hover::before { opacity: 1; }
.post-card:hover {
  box-shadow: 0 24px 64px rgba(0,0,0,0.08), 0 8px 20px rgba(0,0,0,0.04);
  border-color: transparent;
  transform: translateY(-4px);
}
/* Featured layout */
.post-card.featured {
  display: grid;
  grid-template-columns: 1.3fr 1fr;
  grid-template-rows: 1fr auto;
  min-height: 480px;
}
.post-card.featured .card-image { min-height: 480px; grid-row: 1 / -1; }
.post-card.featured .card-body { padding: 48px 44px; display: flex; flex-direction: column; justify-content: center; }
.post-card.featured .card-title { font-size: 36px; line-height: 1.15; }
.post-card.featured .card-excerpt { -webkit-line-clamp: 4; }
.post-card.featured .card-footer { padding: 0 44px 40px; grid-column: 2; }
/* Wide layout */
.post-card.wide {
  display: grid;
  grid-template-columns: 1fr 1.5fr;
  grid-template-rows: 1fr auto;
}
.post-card.wide .card-image { min-height: 300px; grid-row: 1 / -1; }
.post-card.wide .card-body { padding: 40px; display: flex; flex-direction: column; justify-content: center; }
.post-card.wide .card-title { font-size: 28px; }
.post-card.wide .card-footer { padding: 0 40px 32px; grid-column: 2; }

.card-image {
  width: 100%;
  min-height: 240px;
  position: relative;
  overflow: hidden;
  background: var(--gray-800);
}
.card-image-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center center;
  position: absolute;
  inset: 0;
}
.card-image-inner {
  position: absolute;
  inset: 0;
  background:
    repeating-linear-gradient(-45deg, transparent, transparent 30px, rgba(255,151,26,0.05) 30px, rgba(255,151,26,0.05) 32px),
    radial-gradient(circle at 70% 30%, rgba(255,151,26,0.15) 0%, transparent 50%),
    radial-gradient(circle at 20% 80%, rgba(72,229,194,0.1) 0%, transparent 40%);
}
.card-image::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--orange), var(--mint), var(--magenta));
  opacity: 0.6;
  z-index: 1;
}
.card-category {
  position: absolute;
  top: 16px;
  left: 16px;
  font-family: var(--font-ui);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 7px 16px;
  border-radius: 100px;
  background: rgba(0,0,0,0.75);
  backdrop-filter: blur(12px);
  color: var(--white);
  z-index: 2;
  border: 1px solid rgba(255,255,255,0.12);
}
.card-body { padding: 28px 28px 16px; }
.card-meta {
  font-family: var(--font-ui);
  font-size: 13px;
  color: var(--gray-600);
  margin-bottom: 14px;
  display: flex;
  align-items: center;
  gap: 12px;
}
.card-meta-dot {
  width: 3px;
  height: 3px;
  border-radius: 50%;
  background: var(--gray-300);
}
.card-title {
  font-family: var(--font-display);
  font-size: 22px;
  font-weight: 700;
  line-height: 1.22;
  letter-spacing: -0.02em;
  color: var(--gray-800);
  margin-bottom: 12px;
  transition: color 0.3s;

}
.post-card:hover .card-title { color: var(--orange-dark); }
.card-excerpt {
  font-size: 16px;
  color: var(--gray-600);
  line-height: 1.65;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.card-footer {
  padding: 8px 28px 24px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.card-avatar {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--orange), var(--magenta));
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-ui);
  font-size: 10px;
  font-weight: 700;
  color: var(--white);
}
.card-author-name {
  font-family: var(--font-ui);
  font-size: 13px;
  font-weight: 600;
  color: var(--gray-700);
}
@media (max-width: 768px) {
  .post-card.featured,
  .post-card.wide { display: block; }
  .post-card.featured .card-image,
  .post-card.wide .card-image { min-height: 240px; }
  .post-card.featured .card-body,
  .post-card.wide .card-body { padding: 28px; }
  .post-card.featured .card-footer,
  .post-card.wide .card-footer { padding: 0 28px 24px; }
  .post-card.featured .card-title { font-size: 26px; }
  .post-card.wide .card-title { font-size: 22px; }
}
</style>
