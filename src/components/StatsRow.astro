---
interface Stat {
  value: string;
  label: string;
  source?: string;
}
interface Props {
  stats: Stat[];
  heading?: string;
}
const { stats, heading } = Astro.props;
---

<div class="stats-row">
  {heading && <p class="stats-heading">{heading}</p>}
  <div class="stats-inner">
    {stats.map((s) => (
      <div class="stat-item">
        <span class="stat-value">{s.value}</span>
        <span class="stat-label">{s.label}</span>
        {s.source && <span class="stat-source">{s.source}</span>}
      </div>
    ))}
  </div>
</div>

<style>
.stats-row {
  margin: 48px 0;
  padding: 40px;
  background: var(--cream);
  border-radius: 20px;
  border: 1px solid var(--gray-100);
}
.stats-heading {
  font-family: var(--font-ui);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--orange);
  margin-bottom: 28px;
}
.stats-inner {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  gap: 32px;
}
.stat-item {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.stat-value {
  font-family: var(--font-display);
  font-size: 52px;
  font-weight: 900;
  line-height: 1;
  letter-spacing: -0.04em;
  color: var(--black);

  background: linear-gradient(135deg, var(--orange) 0%, var(--magenta) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.stat-label {
  font-family: var(--font-ui);
  font-size: 14px;
  font-weight: 600;
  color: var(--gray-700);
  line-height: 1.35;
}
.stat-source {
  font-family: var(--font-ui);
  font-size: 12px;
  color: var(--gray-400);
  margin-top: 2px;
}
@media (max-width: 640px) {
  .stats-row { padding: 28px 24px; }
  .stats-inner { grid-template-columns: repeat(2, 1fr); gap: 24px; }
  .stat-value { font-size: 40px; }
}
</style>
