---
interface Bar {
  label: string;
  value: number;
  suffix?: string;
  color?: 'orange' | 'magenta' | 'mint';
}
interface Props {
  bars: Bar[];
  heading?: string;
  caption?: string;
  max?: number;
}
const { bars, heading, caption, max } = Astro.props;
const maxValue = max ?? Math.max(...bars.map(b => b.value));
---

<div class="bar-chart reveal">
  {heading && <p class="bc-heading">{heading}</p>}
  <div class="bc-bars">
    {bars.map((bar, i) => {
      const pct = Math.round((bar.value / maxValue) * 100);
      const colorVar = bar.color === 'magenta' ? 'var(--magenta)' : bar.color === 'mint' ? 'var(--mint)' : 'var(--orange)';
      const valueText = `${bar.value}${bar.suffix || '%'}`;
      const isFull = pct >= 95;
      return (
        <div class="bc-row" style={`--delay: ${i * 0.1}s; --pct: ${pct}%`}>
          <span class="bc-label">{bar.label}</span>
          <div class="bc-track" role="meter" aria-valuenow={bar.value} aria-valuemin={0} aria-valuemax={maxValue} aria-label={`${bar.label}: ${valueText}`}>
            <div class="bc-fill" style={`--width: ${pct}%; --bar-color: ${colorVar}`}></div>
            <span class:list={['bc-value', { 'bc-value--inside': isFull }]}>{valueText}</span>
          </div>
        </div>
      );
    })}
  </div>
  {caption && <p class="bc-caption">{caption}</p>}
</div>

<style>
.bar-chart {
  margin: 44px 0;
  padding: 36px 32px;
  background: var(--cream);
  border-radius: 20px;
  border: 1px solid var(--gray-100);
}
.bc-heading {
  font-family: var(--font-ui);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--orange);
  margin-bottom: 24px;
}
.bc-bars {
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.bc-row {
  display: grid;
  grid-template-columns: 140px 1fr;
  align-items: center;
  gap: 16px;
}
.bc-label {
  font-family: var(--font-ui);
  font-size: 13px;
  font-weight: 600;
  color: var(--gray-700);
  line-height: 1.3;
  text-align: right;
}
.bc-track {
  height: 32px;
  background: var(--gray-100);
  border-radius: 8px;
  position: relative;
}
.bc-fill {
  height: 100%;
  width: 0;
  background: linear-gradient(90deg, var(--bar-color), color-mix(in srgb, var(--bar-color) 70%, var(--magenta)));
  border-radius: 8px;
  transition: width 1s var(--ease-expo);
  transition-delay: var(--delay, 0s);
}
.bar-chart.is-visible .bc-fill {
  width: var(--width);
}
.bc-value {
  position: absolute;
  left: calc(var(--pct) + 8px);
  top: 50%;
  transform: translateY(-50%);
  font-family: var(--font-ui);
  font-size: 13px;
  font-weight: 700;
  color: var(--gray-700);
  white-space: nowrap;
  opacity: 0;
  transition: opacity 0.4s ease;
  transition-delay: calc(var(--delay, 0s) + 0.6s);
}
.bc-value--inside {
  left: auto;
  right: 12px;
  color: var(--white);
}
.bar-chart.is-visible .bc-value {
  opacity: 1;
}
.bc-caption {
  font-family: var(--font-ui);
  font-size: 12px;
  color: var(--gray-400);
  margin-top: 16px;
  line-height: 1.5;
}
@media (max-width: 640px) {
  .bar-chart { padding: 28px 20px; }
  .bc-row {
    grid-template-columns: 1fr;
    gap: 6px;
  }
  .bc-label { text-align: left; }
  .bc-track { height: 28px; }
}
</style>

<script>
const charts = document.querySelectorAll('.bar-chart');
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('is-visible');
      observer.unobserve(entry.target);
    }
  });
}, { threshold: 0.2 });
charts.forEach(chart => observer.observe(chart));
</script>
