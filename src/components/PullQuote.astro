---
interface Props {
  quote: string;
  attribution?: string;
}
const { quote, attribution } = Astro.props;
---

<aside class="pull-quote">
  <div class="pq-rule" aria-hidden="true"></div>
  <blockquote class="pq-text">{quote}</blockquote>
  {attribution && <cite class="pq-attribution">{attribution}</cite>}
  <div class="pq-rule" aria-hidden="true"></div>
</aside>

<style>
.pull-quote {
  margin: 52px -48px;
  padding: 0 48px;
  position: relative;
}
.pq-rule {
  height: 2px;
  background: linear-gradient(90deg, var(--orange), var(--magenta), transparent);
  margin-bottom: 28px;
}
.pq-rule:last-child {
  margin-bottom: 0;
  margin-top: 28px;
  background: linear-gradient(90deg, transparent, var(--magenta), var(--orange));
}
.pq-text {
  font-family: var(--font-display);
  font-size: clamp(24px, 3.5vw, 32px);
  font-weight: 600;
  font-style: italic;
  line-height: 1.3;
  letter-spacing: -0.02em;
  color: var(--gray-800);

}
.pq-attribution {
  display: block;
  font-family: var(--font-ui);
  font-size: 13px;
  font-weight: 600;
  color: var(--orange-text);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin-top: 16px;
  font-style: normal;
}
@media (max-width: 768px) {
  .pull-quote { margin: 40px 0; padding: 0; }
  .pq-text { font-size: 22px; }
}
</style>
