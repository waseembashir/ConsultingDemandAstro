---
import BaseLayout from '../layouts/BaseLayout.astro';

const partnerTypes = [
  { title: 'Consulting Firms', description: 'List your firm in our consultant directory. Get matched with vetted briefs from businesses looking for your specialism.' },
  { title: 'Research Partners', description: 'Co-fund original research on the consulting market. Access raw data, co-brand the report, and generate high-quality leads.' },
  { title: 'Technology Partners', description: 'Integrate your consulting marketplace, procurement platform, or SaaS product with our audience and content.' },
  { title: 'Content Contributors', description: 'Share your expertise through guest articles, data contributions, or expert commentary for our editorial pieces.' },
];
---

<BaseLayout
  title="Partner With Us — ConsultingDemand"
  description="Partner with ConsultingDemand. Opportunities for consulting firms, technology platforms, research partners, and expert contributors."
>
  <section class="page-hero">
    <div class="hero-shape hero-shape-1" aria-hidden="true"></div>
    <div class="page-hero-inner">
      <div class="page-eyebrow reveal">Partnerships</div>
      <h1 class="reveal stagger-1">Build with us,<br />not <em>around us.</em></h1>
      <p class="reveal stagger-2">We partner with organizations that share our commitment to making the consulting market more transparent and accessible.</p>
    </div>
  </section>

  <section class="partners-section">
    <div class="partners-inner">
      <div class="partners-grid">
        {partnerTypes.map((p, i) => (
          <div class:list={['partner-card', `reveal stagger-${i + 1}`]}>
            <h2>{p.title}</h2>
            <p>{p.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section reveal">
    <div class="cta-inner">
      <h2>Ready to partner?</h2>
      <p>Tell us about your organization and how you would like to work together. We will get back to you within two working days.</p>
      <a href="/contact" class="btn-primary">Start a Conversation</a>
    </div>
  </section>
</BaseLayout>

<style>
.page-hero { background: var(--black); padding: 100px 48px 120px; position: relative; overflow: hidden; text-align: center; }
.hero-shape { position: absolute; pointer-events: none; border-radius: 50%; }
.hero-shape-1 { top: -10%; right: -5%; width: 500px; height: 500px; background: radial-gradient(circle, rgba(255,151,26,0.08) 0%, transparent 60%); }
.page-hero-inner { max-width: 800px; margin: 0 auto; position: relative; z-index: 1; }
.page-eyebrow { font-family: var(--font-ui); font-size: 12px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--orange); margin-bottom: 24px; }
.page-hero h1 { font-family: var(--font-display); font-size: clamp(40px, 6vw, 72px); font-weight: 900; color: var(--white); line-height: 1.05; letter-spacing: -0.04em; margin-bottom: 20px; }
.page-hero h1 em { font-style: italic; background: linear-gradient(135deg, var(--orange), var(--mint)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.page-hero p { font-family: var(--font-body); font-size: 19px; color: var(--light-text-muted); line-height: 1.6; max-width: 580px; margin: 0 auto; }

.partners-section { padding: 80px 48px; }
.partners-inner { max-width: 1000px; margin: 0 auto; }
.partners-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
.partner-card { background: var(--white); border: 1px solid var(--gray-100); border-radius: 20px; padding: 36px 32px; transition: all 0.3s var(--ease-out); }
.partner-card:hover { transform: translateY(-3px); box-shadow: 0 16px 48px rgba(0,0,0,0.06); }
.partner-card h2 { font-family: var(--font-display); font-size: 22px; font-weight: 800; color: var(--gray-800); margin-bottom: 12px; }
.partner-card p { font-family: var(--font-body); font-size: 15px; color: var(--gray-500); line-height: 1.65; }

.cta-section { background: var(--cream); padding: 80px 48px; text-align: center; }
.cta-inner { max-width: 500px; margin: 0 auto; }
.cta-inner h2 { font-family: var(--font-display); font-size: 36px; font-weight: 900; color: var(--gray-800); margin-bottom: 16px; }
.cta-inner p { font-family: var(--font-body); font-size: 17px; color: var(--gray-500); line-height: 1.65; margin-bottom: 28px; }
.btn-primary {
  display: inline-flex; align-items: center; padding: 16px 40px;
  background: var(--orange); color: var(--black);
  font-family: var(--font-ui); font-size: 14px; font-weight: 700;
  border-radius: 100px; text-decoration: none; transition: all 0.3s var(--ease-out);
}
.btn-primary:hover { background: var(--orange-dark); transform: translateY(-2px); box-shadow: 0 12px 36px rgba(255,151,26,0.2); }

@media (max-width: 768px) {
  .page-hero { padding: 56px 20px 80px; }
  .partners-section, .cta-section { padding: 48px 20px 64px; }
  .partners-grid { grid-template-columns: 1fr; }
}
</style>
